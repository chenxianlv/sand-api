{
  "name": "sand-api",
  "version": "0.0.1",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc -p src/tsconfig.json && tsc -p tests/tsconfig.json && tsc -p demo/tsconfig.json && tsc -p tsconfig.json",
    "check": "pnpm run typecheck && pnpm run test",
    "build": "tsc -p tsconfig.build.json && vite build",
    "format": "prettier --write .",
    "commitlint": "commitlint --from HEAD~1 --to HEAD --verbose",
    "hooks:install": "simple-git-hooks",
    "prepare": "pnpm run hooks:install",
    "prepublishOnly": "pnpm run check",
    "prepack": "pnpm run build",
    "pack:dry-run": "npm pack --dry-run"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged",
    "commit-msg": "pnpm exec commitlint --edit $1",
    "pre-push": "pnpm run check"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs,json,md,yml,yaml}": "prettier --write"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^25.3.3",
    "lint-staged": "^16.1.6",
    "prettier": "^3.8.1",
    "simple-git-hooks": "^2.13.1",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "axios": "^1.13.6"
  }
}
